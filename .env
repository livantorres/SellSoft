# ============================================================
# SellSoft - Variables de Entorno
# Copiar este archivo como .env y completar los valores
# ============================================================

# Entorno: development | production
APP_ENTORNO=development
APP_DEBUG=true
APP_URL=http://sellsoft.test
APP_NOMBRE=SellSoft

# Base de Datos MySQL
DB_HOST=127.0.0.1
DB_PUERTO=3306
DB_NOMBRE=sellsoft_db
DB_USUARIO=root
DB_CLAVE=
DB_CHARSET=utf8mb4

# Seguridad
SECRET_KEY=cambia_esto_por_clave_muy_larga_y_aleatoria_32_chars
SESSION_NOMBRE=sellsoft_sess

# Correo SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PUERTO=587
SMTP_USUARIO=
SMTP_CLAVE=
SMTP_SEGURIDAD=tls
CORREO_REMITENTE=noreply@sellsoft.co
NOMBRE_REMITENTE=SellSoft Sistema

# Zona horaria
ZONA_HORARIA=America/Bogota
